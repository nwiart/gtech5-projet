# clang-format configuration for Unreal Engine 5 style
# Used by clangd for format-on-save

BasedOnStyle: Microsoft
Language: Cpp

# Tabs (UE5 standard)
UseTab: ForIndentation
TabWidth: 4
IndentWidth: 4
ContinuationIndentWidth: 4

# Allman brace style (UE5 standard)
BreakBeforeBraces: Allman
BraceWrapping:
  AfterCaseLabel: true
  AfterClass: true
  AfterControlStatement: Always
  AfterEnum: true
  AfterFunction: true
  AfterNamespace: true
  AfterStruct: true
  AfterUnion: true
  AfterExternBlock: true
  BeforeCatch: true
  BeforeElse: true
  BeforeLambdaBody: false
  BeforeWhile: false
  IndentBraces: false
  SplitEmptyFunction: true
  SplitEmptyRecord: true
  SplitEmptyNamespace: true

# Column limit (0 = off, UE5 doesn't enforce a hard limit)
ColumnLimit: 0

# Pointers/References: left-aligned (UE5 style: int32* Ptr)
PointerAlignment: Left
ReferenceAlignment: Left

# Includes
SortIncludes: Never
IncludeBlocks: Preserve

# Spacing
SpaceBeforeParens: ControlStatements
SpaceAfterCStyleCast: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpaceBeforeSquareBrackets: false
SpaceBeforeAssignmentOperators: true
SpacesBeforeTrailingComments: 1

# Alignment
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignTrailingComments: true

# Short forms
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: false
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortLambdasOnASingleLine: All

# Indentation
AccessModifierOffset: -4
IndentCaseLabels: false
IndentPPDirectives: None
NamespaceIndentation: None

# Other
FixNamespaceComments: true
ReflowComments: false
