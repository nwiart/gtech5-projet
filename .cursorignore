# Add directories or file patterns to ignore during indexing (e.g. foo/ or *.csv)

# ===== Unreal Engine generated / cache =====
Binaries/
Intermediate/
DerivedDataCache/
Saved/
Build/

# ===== Content assets (binaries, not useful for indexing) =====
Content/
*.uasset
*.umap

# ===== IDE / editor files =====
.vs/
.vscode/
.idea/

# ===== Git =====
.git/

# ===== Compiled / binary artifacts =====
*.dll
*.exe
*.lib
*.pdb
*.obj
*.o
*.pch
*.gch

# ===== Solution / project files (generated by UBT) =====
*.sln
*.vcxproj
*.vcxproj.filters

# ===== Clangd generated =====
compile_commands.json
.clangd

# ===== Other =====
*.code-workspace
